{
  "name": "hana-board",
  "version": "1.0.0",
  "description": "🌸 Terminal Kanban board for Linear — open source, runs locally",
  "main": "bin/hana.js",
  "bin": {
    "hana": "./bin/hana.js"
  },
  "type": "module",
  "scripts": {
    "start": "node bin/hana.js",
    "build:web": "npm run build --prefix web",
    "dev:web": "npm run dev --prefix web",
    "prepare": "npm install --prefix web && npm run build --prefix web"
  },
  "files": [
    "bin/",
    "src/",
    "web/out/",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "inquirer": "^9.2.23",
    "ora": "^8.0.1",
    "express": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["linear", "kanban", "board", "cli", "productivity"],
  "license": "MIT"
}
