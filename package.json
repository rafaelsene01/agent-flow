{
  "name": "agent-flow",
  "version": "1.0.0",
  "description": "Agent Flow · Web Kanban board for Linear — open source, runs locally",
  "main": "bin/agent-flow.js",
  "bin": {
    "agent-flow": "./bin/agent-flow.js"
  },
  "type": "module",
  "scripts": {
    "start": "node bin/agent-flow.js",
    "build:web": "npm run build --prefix web",
    "dev:web": "npm run dev --prefix web",
    "prepack": "npm install --prefix web && npm run build --prefix web"
  },
  "files": [
    "bin/",
    "src/",
    "web/out/",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "express": "^5.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["linear", "kanban", "board", "cli", "productivity"],
  "license": "MIT"
}
