{
  "name": "@rafaelsene01/agent-flow",
  "version": "1.0.1",
  "description": "Agent Flow · Web Kanban board for Linear — open source, runs locally",
  "main": "dist/agent-flow.js",
  "bin": {
    "agent-flow": "dist/agent-flow.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"node api/dev.js\" \"npm run dev --prefix web\"",
    "start": "node dist/agent-flow.js",
    "build": "node scripts/build.mjs",
    "build:web": "npm run build --prefix web",
    "postinstall": "node -e \"const fs=require('fs');if(fs.existsSync('web/package.json'))require('child_process').execSync('npm install --prefix web',{stdio:'inherit'})\"",
    "prepack": "npm run build"
  },
  "files": [
    "dist/",
    ".claude/",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "express": "^5.1.0",
    "ora": "^8.0.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "linear",
    "kanban",
    "board",
    "cli",
    "productivity"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.0",
    "javascript-obfuscator": "^5.4.3"
  }
}