{
  "name": "agent-flow",
  "version": "1.0.0",
  "description": "Agent Flow · Web Kanban board for Linear — open source, runs locally",
  "main": "bin/agent-flow.js",
  "bin": {
    "agent-flow": "./bin/agent-flow.js"
  },
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"node api/dev.js\" \"npm run dev --prefix web\"",
    "start": "npm run build:web && node bin/agent-flow.js",
    "build:web": "npm run build --prefix web",
    "postinstall": "npm install --prefix web",
    "prepack": "npm run build --prefix web"
  },
  "files": [
    "bin/",
    "api/",
    "web/out/",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^5.3.0",
    "express": "^5.1.0",
    "ora": "^8.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "linear",
    "kanban",
    "board",
    "cli",
    "productivity"
  ],
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}